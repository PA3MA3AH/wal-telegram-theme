#!/usr/bin/env bash
# wal-telegram-theme — генерирует тему Telegram/AyuGram из цветов pywal
set -euo pipefail

# ── Пути ────────────────────────────────────────────────────────────────────
# Файл с цветами pywal — не трогай, если не менял расположение кеша wal
CACHE_JSON="${HOME}/.cache/wal/colors.json"

# Симлинк на текущие обои — используется как фон внутри темы.
# Если у тебя обои лежат в другом месте, замени на полный путь к файлу,
# например: WALLPAPER_LINK="${HOME}/Pictures/current.jpg"
WALLPAPER_LINK="${HOME}/wallpapers/current"

# Папка где хранится сгенерированный .tdesktop-theme файл
THEME_DIR="${HOME}/.local/share/ayugram-theme"

# Папки tdata для каждого приложения — скрипт запишет тему туда где папка существует.
# Если используешь другой форк (64gram, Kotatogram и т.п.) — добавь его tdata сюда.
AYUGRAM_TDATA="${HOME}/.local/share/AyuGram/tdata"
TELEGRAM_TDATA="${HOME}/.local/share/TelegramDesktop/tdata"
# ────────────────────────────────────────────────────────────────────────────

mkdir -p "${THEME_DIR}"

if [[ ! -f "${CACHE_JSON}" ]]; then
    echo "error: ${CACHE_JSON} not found — run 'wal -i <wallpaper>' first" >&2
    exit 1
fi

CACHE_JSON="$CACHE_JSON" \
WALLPAPER_LINK="$WALLPAPER_LINK" \
THEME_DIR="$THEME_DIR" \
AYUGRAM_TDATA="$AYUGRAM_TDATA" \
TELEGRAM_TDATA="$TELEGRAM_TDATA" \

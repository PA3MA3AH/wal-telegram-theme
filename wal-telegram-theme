    b'\x00\x00\x00\rIHDR\x00\x00\x00\x01\x00\x00\x00\x01'
    b'\x08\x06\x00\x00\x00\x1f\x15\xc4\x89'
    b'\x00\x00\x00\nIDATx\x9cc\x00\x01\x00\x00\x05\x00\x01'
    b'\r\n-\xb4\x00\x00\x00\x00IEND\xaeB`\x82'
)

background_filename = "background.png"
background_data = png_1x1_transparent

if os.path.islink(wallpaper_symlink) or os.path.isfile(wallpaper_symlink):
    try:
        real_path = os.path.realpath(wallpaper_symlink)
        if os.path.isfile(real_path):
            with open(real_path, "rb") as img_file:
                img_bytes = img_file.read()
            if img_bytes[:8] == b'\x89PNG\r\n\x1a\n':
                background_filename = "background.png"
                background_data = img_bytes
            elif img_bytes[:3] == b'\xff\xd8\xff':
                background_filename = "background.jpg"
                background_data = img_bytes
            elif img_bytes[:6] in (b'GIF89a', b'GIF87a'):
                try:
                    result = subprocess.run(
                        ['convert', real_path + '[0]', 'png:-'],
                        capture_output=True, timeout=10
                    )
                    if result.returncode == 0 and result.stdout:
                        background_filename = "background.png"
                        background_data = result.stdout
                    else:
                        raise RuntimeError("convert failed")
                except Exception:
                    background_filename = "background.png"
                    background_data = png_1x1_transparent
            else:
                pass  
    except Exception:
        pass  
# ────────────────────────────────────────────────────────────────────────────

buf = io.BytesIO()
with zipfile.ZipFile(buf, 'w', zipfile.ZIP_DEFLATED) as zf:
    zf.writestr("colors.tdesktop-theme", theme.strip())
    zf.writestr(background_filename, background_data)

theme_data = buf.getvalue()

# Сначала сохраняем основную резервную копию темы в THEME_DIR
